{
  "schemaVersion": 1,
  "id": "musicplayer",
  "version": "${version}",
  "name": "Jukebox",
  "description": "Play music in-game from local files or YouTube. Open with F9.",
  "authors": ["YourName"],
  "contact": {
    "sources": "https://github.com/yourname/musicplayer-mod"
  },
  "license": "MIT",
  "icon": "icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.musicplayer.client.MusicPlayerClient"
    ]
  },
  "mixins": [
    "musicplayer.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.1",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*"
  }
}
